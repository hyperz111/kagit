{
	"name": "kagit",
	"version": "0.0.0",
	"description": "Minimal Git Hooks",
	"keywords": [],
	"repository": "https://github.com/hyperz111/kagit.git",
	"license": "MIT",
	"author": "Hyper-Z11 (https://github.com/hyperz111)",
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc",
		"format": "prettier -w .",
		"prepublishOnly": "pnpm run build",
		"test": "node --test",
		"types": "tsc --noEmit"
	},
	"devDependencies": {
		"@hyperz111/prettier-config": "^1",
		"@hyperz111/tsconfig": "^1",
		"prettier": "^3",
		"typescript": "^6"
	},
	"packageManager": "pnpm@10.15.0"
}
