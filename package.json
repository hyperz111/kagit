{
	"name": "kagit",
	"version": "0.0.0",
	"description": "Minimal Git Hooks",
	"keywords": [
		"git",
		"hooks"
	],
	"repository": "hyperz111/kagit",
	"license": "MIT",
	"author": "Hyper-Z11",
	"type": "module",
	"bin": "bin/kagit.js",
	"scripts": {
		"format": "prettier -w .",
		"prepare": "node ./bin/kagit.js",
		"test": "node --test",
		"types": "tsc --noEmit"
	},
	"devDependencies": {
		"@hyperz111/prettier-config": "^1.1.0",
		"@hyperz111/tsconfig": "^1",
		"@types/node": "^25.6.0",
		"clean-publish": "^7.0.1",
		"nano-staged": "^1.0.2",
		"prettier": "^3",
		"typescript": "^6"
	},
	"packageManager": "pnpm@10.15.0",
	"kagit": {
		"pre-commit": "pnpm exec nano-staged"
	}
}
