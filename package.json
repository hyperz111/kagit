{
	"name": "kagitin",
	"version": "0.2.1",
	"description": "Minimal Git Hooks",
	"keywords": [
		"git",
		"hooks"
	],
	"repository": "hyperz111/kagitin",
	"license": "MIT",
	"author": "Hyper-Z11",
	"type": "module",
	"bin": "bin/index.js",
	"scripts": {
		"format": "prettier -w .",
		"prepare": "node bin",
		"test": "node --test",
		"types": "tsc --noEmit"
	},
	"devDependencies": {
		"@hyperz111/prettier-config": "^1.1.0",
		"@hyperz111/tsconfig": "^1",
		"@types/node": "^25.6.0",
		"nano-staged": "^1.0.2",
		"prettier": "^3",
		"typescript": "^6"
	},
	"packageManager": "pnpm@10.15.0",
	"kagitin": {
		"pre-commit": "pnpm exec nano-staged"
	}
}
